# ~/.config/ghostty/config
# Haunting terminal aesthetic — heraldstack
# Copy to: ~/.config/ghostty/config

font-family = "JetBrainsMono Nerd Font"
font-size = 14

# Tokyo Night palette
background = "#1a1b26"
foreground = "#c0caf5"

cursor-color = "#7dcfff"
cursor-style = block

selection-background = "#283457"
selection-foreground = "#c0caf5"

# Window
background-opacity = 0.92
macos-titlebar-style = hidden
window-padding-x = 12
window-padding-y = 10

# Tokyo Night 16-color palette
palette = 0=#15161e
palette = 1=#f7768e
palette = 2=#9ece6a
palette = 3=#e0af68
palette = 4=#7aa2f7
palette = 5=#bb9af7
palette = 6=#7dcfff
palette = 7=#a9b1d6
palette = 8=#414868
palette = 9=#f7768e
palette = 10=#9ece6a
palette = 11=#e0af68
palette = 12=#7aa2f7
palette = 13=#bb9af7
palette = 14=#7dcfff
palette = 15=#c0caf5
